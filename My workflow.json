    {
      "parameters": {
        "jsCode": "for (const item of items) {\n\n  const machineMap = {\n    \"CNC\": 0,\n    \"Compressor\": 1,\n    \"Pump\": 2,\n    \"Robotic Arm\": 3\n  };\n\n  const modeMap = {\n    \"idle\": 0,\n    \"normal\": 1,\n    \"peak\": 2\n  };\n\n  item.json.machine_type =\n    machineMap[item.json.machine_type];\n\n  item.json.operating_mode =\n    modeMap[item.json.operating_mode];\n}\n\nreturn items;"
      },
