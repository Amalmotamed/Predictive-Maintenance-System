        "jsCode": "const avgVibration =\nitems.reduce((s,i)=>s+Number(i.json.vibration_rms),0)/items.length;\n\nconst avgTemperature =\nitems.reduce((s,i)=>s+Number(i.json.temperature_motor),0)/items.length;\n\nconst avgCurrent =\nitems.reduce((s,i)=>s+Number(i.json.current_phase_avg),0)/items.length;\n\nconst avgPressure =\nitems.reduce((s,i)=>s+Number(i.json.pressure_level),0)/items.length;\n\nconst avgRPM =\nitems.reduce((s,i)=>s+Number(i.json.rpm),0)/items.length;\n\nconst maxPrediction =\nMath.max(...items.map(i=>Number(i.json.prediction)));\n\nconst failureType =\nitems.find(i => i.json.prediction === 1)?.json.failure_type\n?? items[0].json.failure_type;\n\nreturn [{\n  json: {\n    prediction: maxPrediction,\n    failure_type: failureType,\n    machine_type: items[0].json.machine_type,\n    avg_vibration: avgVibration,\n    avg_temperature: avgTemperature,\n    avg_current: avgCurrent,\n    avg_pressure: avgPressure,\n    avg_rpm: avgRPM\n  }\n}];"
